{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动前端",
      "type": "npm",
      "script": "dev",
      "path": "frontend/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": { "activeOnStart": true, "beginsPattern": "VITE", "endsPattern": "ready in" }
      },
      "presentation": { "group": "dev", "panel": "dedicated", "showReuseMessage": false }
    },
    {
      "label": "启动后端",
      "type": "shell",
      "command": "venv/Scripts/python.exe run.py",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": { "regexp": "^$" },
        "background": { "activeOnStart": true, "beginsPattern": "Uvicorn running", "endsPattern": "Uvicorn running" }
      },
      "presentation": { "group": "dev", "panel": "dedicated", "showReuseMessage": false }
    },
    {
      "label": "开发模式 (前后端)",
      "dependsOn": ["启动前端", "启动后端"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
